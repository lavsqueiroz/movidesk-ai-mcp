# ═══════════════════════════════════════════════════════════════
# MOVIDESK AI MCP - VARIÁVEIS DE AMBIENTE
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no Git!
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# SERVIDOR HTTP
# ─────────────────────────────────────────────────────────────
MCP_HTTP_PORT=9002
MCP_HTTP_HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────
# MOVIDESK API
# ─────────────────────────────────────────────────────────────
MOVIDESK_TOKEN=seu-token-aqui
MOVIDESK_URL=https://newm.movidesk.com

# ─────────────────────────────────────────────────────────────
# SUPERDOC MCP (servidor rodando)
# ─────────────────────────────────────────────────────────────
SUPERDOC_URL=http://servidor-superdoc:9001
# Se rodando local use: http://host.docker.internal:9001

# ─────────────────────────────────────────────────────────────
# SEGURANÇA (opcional para desenvolvimento)
# ─────────────────────────────────────────────────────────────
AUTH_ENABLED=false
CORS_ENABLED=true

# ─────────────────────────────────────────────────────────────
# LOGS E DEBUG
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development