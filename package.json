{
  "name": "movidesk-ai-mcp",
  "version": "2.0.0",
  "description": "MCP Server para análise automática de tickets do Movidesk usando IA - Sistema com Aprovação Humana",
  "type": "module",
  "main": "dist/mcp-server/server-http-entry.js",
  "scripts": {
    "dev": "tsx watch src/mcp-server/server-http-entry.ts",
    "build": "tsc",
    "build:clean": "rimraf dist && tsc",
    "start": "node dist/mcp-server/server-http-entry.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
